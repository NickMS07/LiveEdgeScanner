# ── Phoenix API (edge_api) ──────────────────────────────
DATABASE_URL=ecto://edge_api:edge_api_dev@localhost/edge_api_dev
REDIS_URL=redis://localhost:6379
SECRET_KEY_BASE=run_mix_phx_gen_secret_to_generate_this_value
SCRAPER_API_KEY=change-me-to-a-strong-random-key
PHX_HOST=localhost
PORT=4000

# For production (Fly.io):
# PHX_HOST=your-app-name.fly.dev

# ── Scrapers ────────────────────────────────────────────
EDGE_API_URL=http://localhost:4000
# SCRAPER_API_KEY must match the one above
SCRAPER_API_KEY=change-me-to-a-strong-random-key
SCRAPE_INTERVAL=60000

# ── Frontend ────────────────────────────────────────────
# Set these as window globals or use Next.js env:
NEXT_PUBLIC_WS_URL=ws://localhost:4000/socket/websocket
NEXT_PUBLIC_API_URL=http://localhost:4000
